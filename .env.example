NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/wemove

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Twilio (SMS / OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Firebase (Push notifications)
FIREBASE_PROJECT_ID=wemove-app
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@wemove-app.iam.gserviceaccount.com

# Payments
MOMO_API_KEY=your-momo-api-key
MOMO_API_USER=your-momo-api-user
GHANAPAY_API_KEY=your-ghanapay-api-key

# WeMove
COMMISSION_RATE=0.15
FLOOR_FARE_GHS=10
PER_KM_RATE_GHS=1.5
OTP_EXPIRY_SECONDS=300
